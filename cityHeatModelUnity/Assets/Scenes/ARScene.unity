  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "GENERATION OF TEMPERATURE DATA\n\nThe following types of areas were taken
    into account for the visualization:\n\u2022 Buildings\n\u2022 Parking areas\n\u2022
    Roads, paths, and parking lots\n\u2022 Railway lines\n\u2022 Forests\n\u2022
    Residential areas\n\nThe cooling and warming effects were estimated and cross-checked
    using several sources:\n\u2022 Climate model 2022 for the city of Berlin\n\u2022
    U.S. Environmental Protection Agency (EPA)\n\u2022 Case study on urban heat islands
    (Hanover)\n\nBased on the Berlin climate model, an attempt was made to take wind
    influences into account. Cooler air from forest areas can be transported to adjacent
    areas, while buildings block the wind or create wind shadows.\n\nIMPORTANT NOTE:\nThis
    model does not represent a realistic or validated climate model.\nIt is intended
    for rough guidance only and is not suitable for scientific or planning conclusions."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
